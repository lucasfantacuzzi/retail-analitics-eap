<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             version="3.0"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="retailPU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/RetailDS</jta-data-source>
        <class>com.example.retail.domain.SaleRecord</class>
        <properties>
            <!-- Em dev/lab, "update" evita erro quando a tabela já existe -->
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="jakarta.persistence.schema-generation.create-source" value="metadata"/>
        </properties>
    </persistence-unit>
</persistence>

